# ==============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env.local for local development
# ==============================================================================

# ==============================================================================
# SUPABASE CONFIGURATION
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
NEXT_PUBLIC_SUPABASE_JWT_SECRET=your-jwt-secret-here

# ==============================================================================
# REDIS/UPSTASH CONFIGURATION (Required for job queue & caching)
# ==============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OR use Upstash Redis (recommended for production)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ==============================================================================
# META/FACEBOOK ADS API
# ==============================================================================
FACEBOOK_APP_ID=your-app-id
FACEBOOK_APP_SECRET=your-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/meta/callback

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================
NODE_ENV=development
LOG_LEVEL=debug
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================================================
# ERROR TRACKING (Optional)
# ==============================================================================
# Sentry
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ==============================================================================
# EMAIL SERVICE (Optional, for notifications)
# ==============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="AdPilot AI" <noreply@adpilot.ai>

# ==============================================================================
# MONITORING & OBSERVABILITY (Optional)
# ==============================================================================
# DataDog
DATADOG_API_KEY=
DATADOG_APP_KEY=

# ==============================================================================
# FEATURE FLAGS (Optional)
# ==============================================================================
ENABLE_BACKGROUND_JOBS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_METRICS_COLLECTION=true

# ==============================================================================
# SECURITY
# ==============================================================================
# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session timeout (in seconds)
SESSION_TIMEOUT=3600
SESSION_ABSOLUTE_TIMEOUT=86400
