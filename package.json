    "@types/ioredis": "^4.28.10",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "bull": "^4.16.5",
    "exceljs": "^4.4.0",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
