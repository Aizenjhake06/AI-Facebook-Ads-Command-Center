{
  "name": "project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "setup": "ts-node scripts/setup.ts",
    "worker:sync": "ts-node src/lib/jobs/sync-worker.ts",
    "worker:alerts": "ts-node src/lib/jobs/alert-worker.ts",
    "worker:reports": "ts-node src/lib/jobs/report-worker.ts",
    "worker:notifications": "ts-node src/lib/jobs/notification-worker.ts",
    "worker:all": "concurrently \"npm run worker:sync\" \"npm run worker:alerts\" \"npm run worker:reports\" \"npm run worker:notifications\"",
    "db:migrate": "echo 'Run migrations via Supabase CLI or dashboard'",
    "db:seed": "ts-node scripts/seed.ts",
    "validate": "npm run lint && npm run test && npm run build",
    "validate:deployment": "ts-node scripts/validate-deployment.ts"
  },
  "dependencies": {
    "@netlify/plugin-nextjs": "^5.15.12",
